{
  "schemaVersion": 1,
  "purpose": "Single source of truth for html-anything style metadata. Style prompts define the full contract; this catalog keeps routing, examples, previews, triggers, and quality checks synchronized.",
  "inspiredBy": [
    {
      "name": "nexu-io/open-design",
      "url": "https://github.com/nexu-io/open-design",
      "borrowed": [
        "style metadata lives next to the prompt",
        "every serious style has a concrete example and preview",
        "design systems and layout systems are distinct responsibilities",
        "style prompts include preflight checks, required primitives, and anti-patterns"
      ]
    }
  ],
  "sharedQualityGates": [
    "Root html must declare data-ha-style.",
    "First viewport must reveal the style scaffold before any generic report modules.",
    "At least four style-native primitives from the selected style must appear in the HTML.",
    "Source-required modules must be translated into the style, not pasted as generic cards.",
    "Interactive controls need accessible names, focus states, and a keyboard path.",
    "Generated outputs must avoid fake metrics, filler labels, and generic AI product copy."
  ],
  "useCases": [
    {
      "id": "teaching",
      "title": "Teaching Studios",
      "summary": "Turn an idea, lesson, article, or technical concept into an interactive learning studio instead of a scrolling article.",
      "styles": ["teaching", "interactive-learning", "comic-book"],
      "examples": ["solar-system-studio", "ai-tokens-comic"]
    },
    {
      "id": "files-work",
      "title": "Files & Work Data",
      "summary": "Transform spreadsheets, CSV exports, PDFs, DOCX, Markdown, records, logs, calendars, work artifacts, and slide-style carousel outputs into polished live HTML.",
      "styles": ["dashboard", "soft-saas", "document", "kami-reading", "architectural-spread", "digital-eguide", "editorial-carousel", "paper-trail", "living-essay"],
      "examples": ["email", "csv", "pdf", "docx", "markdown", "editorial-carousel"]
    },
    {
      "id": "conversation",
      "title": "Conversation Analysis",
      "summary": "Analyze private chats, relationship threads, team channels, and message exports through rhythm, contribution, and evidence.",
      "styles": ["relationship", "love-romance-3d", "kinetic-scoreboard", "network-map"],
      "examples": ["wechat-couple", "slack"]
    },
    {
      "id": "personal-data",
      "title": "Personal Data & Places",
      "summary": "Turn personal exports, timelines, routes, saved places, trip records, reading fields, payments, and notes into personal stories and atlases.",
      "styles": ["timeline-story", "living-essay", "network-map", "map-atlas", "paper-trail"],
      "examples": ["amazon-orders", "iphone-health", "kindle-highlights", "rideshare-history"]
    },
    {
      "id": "developer",
      "title": "Developer Evidence",
      "summary": "Turn diffs, pull requests, CI logs, stack traces, and repos into evidence workbenches for review and debugging.",
      "styles": ["developer", "terminal-cli"],
      "examples": ["git-diff", "ci-log"]
    }
  ],
