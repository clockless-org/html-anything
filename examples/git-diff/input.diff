diff --git a/src/auth/session.ts b/src/auth/session.ts
index 1a2b3c4..5d6e7f8 100644
--- a/src/auth/session.ts
+++ b/src/auth/session.ts
@@ -1,12 +1,18 @@
 import * as jwt from "jsonwebtoken"
 import { logger } from "../obs/logger"

+const EXPECTED_ISSUER = process.env.SESSION_ISSUER || "clockless.ai"
+const CLOCK_SKEW_SECONDS = 30
+
 export function verifySession(token: string) {
   if (!token) return null
-  const decoded = jwt.decode(token) as { exp: number; sub: string }
-  if (decoded.exp < Date.now()) {
-    logger.info({ sub: decoded.sub }, "session expired")
+  const decoded = jwt.decode(token) as { exp: number; sub: string; iss?: string } | null
+  if (!decoded) return null
+  if (decoded.iss !== EXPECTED_ISSUER) {
+    logger.warn({ iss: decoded.iss }, "unexpected issuer")
+    return null
+  }
+  if (decoded.exp < Math.floor(Date.now() / 1000) - CLOCK_SKEW_SECONDS) {
+    logger.info({ sub: decoded.sub }, "session expired")
     return null
   }
   return decoded
 }
