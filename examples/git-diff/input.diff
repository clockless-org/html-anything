 })
diff --git a/migrations/0042_session_issuer.sql b/migrations/0042_session_issuer.sql
new file mode 100644
index 0000000..7654321
--- /dev/null
+++ b/migrations/0042_session_issuer.sql
@@ -0,0 +1,9 @@
+-- 0042_session_issuer
+-- Adds issuer column to sessions for cross-issuer verification.
+-- Backfills existing rows to the legacy issuer; safe under concurrent writes.
+
+ALTER TABLE sessions ADD COLUMN issuer TEXT;
+UPDATE sessions SET issuer = 'clockless.ai' WHERE issuer IS NULL;
+ALTER TABLE sessions ALTER COLUMN issuer SET NOT NULL;
+
+CREATE INDEX CONCURRENTLY idx_sessions_issuer ON sessions (issuer);
